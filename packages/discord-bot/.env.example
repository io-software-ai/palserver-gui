# ── Discord 應用程式設定 ──────────────────────────────────────────────
# Discord Developer Portal(discord.com/developers/applications)建立 Application
# 後,「Bot」分頁重新產生(Reset Token)取得的 bot token。
DISCORD_TOKEN=

# 同一個 Application 頁面最上方的 Application ID。
DISCORD_CLIENT_ID=

# 要安裝這個 bot 的 Discord 伺服器(guild)ID。Discord 用戶端開啟開發者模式後,
# 右鍵伺服器圖示 → 複製伺服器 ID。
DISCORD_GUILD_ID=

# ── agent 連線設定 ────────────────────────────────────────────────────
# agent 的 REST API 位置,不需要結尾斜線。bot 與 agent 同機部署時用預設值即可;
# 分開部署時改成 agent 主機的位址(例如 Tailscale 內網位址)。
AGENT_URL=http://127.0.0.1:8250

# 怎麼拿 AGENT_TOKEN:
#   1. agent 主機的 data-dir 底下有一個 token 檔(原生安裝預設在 ~/.palserver-agent/token,
#      docker 部署則在 PALSERVER_DATA_DIR 指到的目錄下),檔案內容就是這個長 token,
#      直接複製貼上即可。
#   2. 或是打開 GUI 的「設定」頁,用配對碼(短碼)在瀏覽器完成一次配對,
#      配對後同一份 token 一樣會寫進上面那個檔案,再照方法 1 取用。
AGENT_TOKEN=

# 選填:固定操作某一個實例(agent 可能同時管理多個伺服器)。留空則自動使用
# agent 回傳清單的第一個實例。實例 id 可在 GUI 網址列,或呼叫 agent 的
# GET /api/instances 回應中找到。
AGENT_INSTANCE_ID=

# 選填:embed 左上角品牌小圖示的公開網址(例如放在 CDN 上的 logo)。留空則不顯示圖示。
BRAND_ICON_URL=
